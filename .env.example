# Anthropic – LLM für Antwortgenerierung
ANTHROPIC_API_KEY=sk-ant-...

# Ollama auf Hostinger VPS via Tailscale
# Tailscale-IP des VPS ermitteln: auf VPS "tailscale ip -4" ausführen
OLLAMA_BASE_URL=http://100.x.x.x:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Chainlit-Authentifizierung
# Secret generieren: python -c "import secrets; print(secrets.token_hex(32))"
CHAINLIT_AUTH_SECRET=
CHAINLIT_USER=pilot
CHAINLIT_PASSWORD=

# App
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=4
LOG_LEVEL=INFO
