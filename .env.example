# =============================================================
# Diese Variablen in Hostinger unter "Environment Variables" eintragen.
# Fuer lokale Entwicklung: diese Datei nach .env kopieren und befuellen.
# WICHTIG: .env niemals committen – steht in .gitignore
# =============================================================

# -------------------------------------------------------------
# Anthropic – LLM fuer Antwortgenerierung
# Quelle: https://console.anthropic.com → API Keys
# -------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------------------------
# Ollama – selbst gehostete Embeddings auf Hostinger VPS
# OLLAMA_BASE_URL: http://<Tailscale-IP>:<Port>
# Tailscale-IP ermitteln: auf VPS "tailscale ip -4" ausfuehren
# Port des Ollama-Containers pruefen: "docker ps | grep ollama"
# Beispiel: http://100.103.54.4:32768
# -------------------------------------------------------------
OLLAMA_BASE_URL=http://100.x.x.x:32768
OLLAMA_EMBED_MODEL=nomic-embed-text

# -------------------------------------------------------------
# Supabase – Vektordatenbank (pgvector)
# Quelle: https://supabase.com → Projekt → Settings → API
# SUPABASE_SERVICE_KEY: "service_role" Key verwenden (nicht "anon"!)
# -------------------------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# -------------------------------------------------------------
# PostgreSQL-Verbindungen – zwei URLs fuer unterschiedliche Zwecke:
#
# DATABASE_URL: Direkte Verbindung (Port 5432) – nur fuer Alembic-Migrationen
#   Quelle: Supabase → Connect → ORMs → "Direct URL"
#
# ASYNC_DATABASE_URL: Transaction Pooler (Port 6543) – fuer Chainlit-Laufzeitabfragen
#   Quelle: Supabase → Connect → ORMs → "DATABASE_URL" (Pooler)
#   Schema von postgresql:// auf postgresql+asyncpg:// aendern!
# -------------------------------------------------------------
DATABASE_URL=postgresql://postgres:your-password@db.xxxx.supabase.co:5432/postgres
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres.xxxx:your-password@aws-0-xx.pooler.supabase.com:6543/postgres

# -------------------------------------------------------------
# Chainlit-Authentifizierung
#
# CHAINLIT_AUTH_SECRET: zufaelliger 64-Zeichen Hex-String fuer JWT-Signing
# Generieren mit:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Beispiel (NICHT verwenden – nur zur Veranschaulichung):
#   dbc095b60be24746165fc80d03deb8bab9beb23cc58efed1e3eca5bbfdb81a90
#
# CHAINLIT_USER: Login-Benutzername fuer den Piloten
# CHAINLIT_PASSWORD: sicheres Passwort (mind. 12 Zeichen empfohlen)
# -------------------------------------------------------------
CHAINLIT_AUTH_SECRET=
CHAINLIT_USER=pilot
CHAINLIT_PASSWORD=

# -------------------------------------------------------------
# RAG-Parameter (Standardwerte koennen unveraendert bleiben)
# -------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=4
LOG_LEVEL=INFO
